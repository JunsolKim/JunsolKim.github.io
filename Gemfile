source "https://rubygems.org"

# GitHub Pages — pins Jekyll + plugins to the versions GitHub builds with.
# This way, what you see locally matches what GitHub serves.
gem "github-pages", group: :jekyll_plugins

# Performance-booster for watching directories on macOS/Linux.
gem "wdm", "~> 0.1", :platforms => [:mingw, :x64_mingw, :mswin]

# Required for Ruby 3+
gem "webrick"
